{
    "layer": "top",
    "position": "top",
    "height": 40,
    "spacing": 10,
    "margin": "0, 0, -10, 0",
    "modules-left": ["custom/launcher", "hyprland/workspaces", "cava", "custom/recorder", "custom/audiorec", "custom/playerctl"],
    "modules-center": ["mpd"],
    "modules-right": ["tray", "idle_inhibitor", "disk", "pulseaudio", "network", "battery", "clock", "custom/power"],

    "hyprland/workspaces": {
        "format": "{name}",
        "format-icons": {
            "1": "ґ░И╣",
            "2": "ґ░УЗ",
            "3": "ґ░УУ",
            "5": "ґ░ЖН",
            "urgent": "ґ░ИЕ",
            "focused": "ґ░Дп",
            "default": "ґ░ЬЛ"
        },
        "window-rewrite-default": "ґ░Дп",
        "window-rewrite": {
            "class<firefox>": "ґ░И╣",
            "class<alacritty>": "ґ░ЖН",
            "class<spotify>": "ґ░УЗ"
        }
    },

    "custom/playerctl": {
        "format": "{icon}  {text}",
        "return-type": "json",
        "max-length": 60,
        "exec": "playerctl -p spotify metadata --format '{\"text\": \"{{markup_escape(artist)}} - {{markup_escape(title)}}\", \"tooltip\": \"{{playerName}} : {{markup_escape(title)}}\", \"alt\": \"{{status}}\", \"class\": \"{{status}}\"}' -F",
        "on-click": "playerctl -p spotify play-pause",
        "on-scroll-up": "playerctl -p spotify volume .05+",
        "on-scroll-down": "playerctl -p spotify volume .05-",
        "format-icons": {
          "Playing" : "<span>ґ░Пе </span>",
          "Paused" : "<span>яЕД </span>",
          "Stopped" : "<span>яЕД </span>"
        }
    },

    "custom/launcher": {
        "format":"яМУ",
        "on-click": "rofi -show drun -i",
        "tooltip": false,
    },

    "sway/window": {
        "max-length": 25,
        "tooltip": false
    },

    "clock": {
        "interval": 1,
        "locale": "C", 
        "format": "яБ│  {:%a, %b %d ґ░еФ  %H:%M:%S}",
        "format-alt": "{:%H:%M}", // Icon: calendar-alt
        "tooltip": false
    },

    "cpu": {
        "interval": 10,
        "format": "яЛЫ  {usage}%",
        "max-length": 10,
        "on-click": "kitty -e 'htop'"
    },

    "memory": {
        "interval": 30,
        "format": "яГЙ  {used:0.2f}GB",

        "max-length": 10,
        "tooltip": false,
        "warning": 70,
        "critical": 90
    },

    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}   {capacity}%",
        "format-charging": "тЪб{capacity}%",
        "format-plugged": "яЗж  {capacity}%",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
        //"format-alt": "{time}",
    },

    "temperature": {
        "critical-threshold": 80,
        "format-critical": "{temperatureC}┬░ яЛЗ",
        "format": "{temperatureC}┬░ яЛЙ"
    },

    "network": {
        "format": "{icon} юкЪ {bandwidthDownBits}",
        "format-alt": "{ipaddr}/{cidr} {icon}",
        "format-alt-click": "click-right",
        "format-wifi": "{icon} юкЪ {bandwidthDownBits}",
        "format-icons": {
            "wifi": ["ґ░дЯ", "ґ░дв" ,"ґ░ди"],
            "ethernet": ["ґ░ИА"],
            "disconnected": ["ґ░ЕЫ"]
        },
        "tooltip-format": "{ifname}: {ipaddr}",
    },

    "pulseaudio": {
      // "scroll-step": 1, // %, can be a float
      "format": "{icon}  {volume}%",
      "format-bluetooth": "{icon}яКФ {volume}%",
      "format-bluetooth-muted": "яСж ",
      "format-muted": "яСж  {format_source}",
      "format-source": "яД░ {volume}%",
      "format-source-muted": "яД▒",
      "format-icons": {
        "headphone": "яАе ",
        "hands-free": "яЦР",
        "headset": "ЁЯОз",
        "phone": "яВХ",
        "portable": "яВХ",
        "car": "яЖ╣",
        "default": ["яАж", "яАз", "яАи"]
      },
      "on-click": "pavucontrol"
    },

    "backlight": {
        "device": "intel_backlight",
        "format": "{icon}  {percent}%",
        "format-icons": ["тШАя╕П", "яЖЕ"],
        "on-scroll-down": "brightnessctl -c backlight set 1%-",
        "on-scroll-up": "brightnessctl -c backlight set +1%"
    },

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons":{
            "activated": "яБо",
            "deactivated": "яБ░"
        }
    },

    "tray": {
        "icon-size": 15
    },

    "disk": {
        "format": "яВа  {free}" 
    },

    "custom/recorder": {
        "format": "яА╜ Rec",
        "format-disabled": "яА╜ Off-air", //An empty format will hide the module.
        "return-type": "json",
        "interval": 1,
        "exec": "echo '{\"class\": \"recording\"}'",
        "exec-if": "pgrep wf-recorder",
    },

    "custom/audiorec": {
        "format": "тЩм Rec",
        "format-disabled": "тЩм Off-air", //An empty format will hide the module.
        "return-type": "json",
        "interval": 1,
        "exec": "echo '{\"class\": \"audio recording\"}'",
        "exec-if": "pgrep ffmpeg",
    },

    "mpd": {
      "format": "{stateIcon} {artist} - {title}",
      "format-disconnected": "ЁЯО╢",
      "format-stopped": "тЩк",
      "interval": 10,
      "consume-icons": {
        "on": "яГД " // Icon shows only when "consume" is on
      },
      "random-icons": {
        "off": "<span color=\"#f53c3c\">яБ┤</span> ", // Icon grayed out when "random" is off
        "on": "яБ┤ "
      },
      "repeat-icons": {
        "on": "яАЮ "
      },
      "single-icons": {
        "on": "яАЮ1 "
      },
      "state-icons": {
        "paused": "яБМ",
        "playing": "яБЛ"
      },
      "tooltip-format": "MPD (connected)",
      "tooltip-format-disconnected": "MPD (disconnected)",
      "max-length": 45
    },

    "custom/power": {
        "format":"яАС",
        "on-click": "exec ~/.config/scripts/power.sh",
        "tooltip": false,
    },

    "cava": {
        "framerate": 60,
        "autosens": 0,
        "bars": 14,
        "lower_cutoff_freq": 50,
        "higher_cutoff_freq": 24000,
        "method": "pipewire",
        "source": "auto",
        "stereo": true,
        "reverse": false,
        "bar_delimiter": 0,
        "monstercat": false,
        "waves": false,
        "noise_reduction": 0.77,
        "input_delay": 2,
        "format-icons" : ["тЦБ", "тЦВ", "тЦГ", "тЦД", "тЦЕ", "тЦЖ", "тЦЗ", "тЦИ" ],
        "actions": {
                   "on-click-right": "mode"
                   }
    }
}
